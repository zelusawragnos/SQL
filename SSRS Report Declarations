WITH odrtyp AS(
SELECT company ,order_cat ,order_sub_cat
FROM category
WHERE company = @company

)
/*
 reference defintion table for category. compare definition table to list of query parameters
*/
, cnt as(
SELECT odrtyp.company ,odrtyp.order_cat ,count(odrtyp.order_cat) param_cnt ,max(cnt) cat_cnt ,max(all_cnt) all_cnt
FROM odrtyp 
	CROSS APPLY(select company ,order_cat ,count(order_cat) cnt	from category z where z.company = odrtyp.ag_id and z.tycod = odrtyp.tycod group by copmany ,order_cat	)AS cat 
	CROSS APPLY(select company ,count(company) all_cnt		from category		z where z.company = odrtyp.company  group by company								)AS comp_cnt
GROUP BY odrtyp.company ,odrtyp.order_cat

), aggregator AS(
/*
	all categories included return '*'/all sub_cat, return distinct cat/sub-set, cat concatanated with subs
*/
SELECT tyc ordertyp ,row_number()over(order by tyc) rn
FROM(
	select concat(odrtyp.order_cat ,': ' ,string_agg(order_sub_cat,' ') within group(order by order_sub_cat)) tyc
	from odrtyp
		left join cnt on odrtyp.order_cat = cnt.tycod
	where param_cnt<>tycod_cnt
	group by odrtyp.oder_cat		union all
	select distinct 
		'*'
	from cnt
	where all_cnt=param_cnt
		union all
	select distinct 
		case when all_cnt = param_cnt THEN 'ALL' ELSE ordertyp.order_cat END order_cat
	from odretyp
		left join cnt on odrtyp.tycod = cnt.order_cat
	where param_cnt = cat_cnt AND all_cnt <> param_cnt
)
	AS z

),maxrn as(
--for parameters following order cat, add rn to report dec rn to keep report dec order
select max(rn)+14 rn
from tycod_agg

)
/*Return report declarations as table*/
SELECT 1 rn		,'1. Report title' title	,null subheader UNION
SELECT 2		,null						,'Order Type:'		UNION		
SELECT 2+rn	,null						,concat('   ',ordertyp					) FROM aggregator		UNION				
SELECT 3+rn	,null						,concat('Location: ',@location				) FROM maxrn			UNION		
