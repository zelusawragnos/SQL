DECLARE @interval int = 100
;
WITH orders AS(
/*Return current day hydrant events - if any record has occurred since last execution, assign 1 */
SELECT distinct	
	order
	,date
	,CASE WHEN datediff(second,date,getdate())<=@interval THEN 1 END f
FROM orders
WHERE date beween dateadd(hour,-7,getdate()) and getdate()

)
/*
	No valid record errors query & report send fails
	Valid record succesfuly executres query
*/
SELECT * FROM orders
	UNION
SELECT null,left('p',count(num_1)-1),null,null,null,null,null,null FROM ae WHERE force_fail = 1
ORDER BY ts desc
