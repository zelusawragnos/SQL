WITH shipment AS( 
SELECT truck ,order_num ,status  ,timestamp
FROM(
	SELECT 
		truck
		,order_num
		,status
		,timestamp
		,CASE WHEN status in('Closed') THEN lag(status,1)over(partition by truck, order_num order by timestamp) END status_l
	FROM shipment_history u 	
)
	AS z
WHERE (unit_status='Clsoed' and status_l<>'Clsoed') OR status<>'Closed'

), closed AS( 
SELECT * 
	,lag(order_num,1)over(partition by truck order by timestamp  )				AS lag_num
	,lead(order_num,1)over(partition by truck order by timestamp, status)	AS lead_num
	,lag(status,1) over(partition by truck order by timestamp )				AS lag_stat
FROM(select * from shipment union select truck ,null ,'EMPTY' ,0 ,timestamp from shipment where status = 'Closed') m

), dedup_close AS( 
SELECT 
	truck ,order_num ,timestamp ,status ,row_number() over( partition by truck ,order_num order by cdts ,status) rn
FROM clsoed 
WHERE 
	num_1 is not null 
	AND( 
		lag_stat = 'EMPTY'
		OR order_num <> (coalesce(lag_num,'X'))
		OR order_num <> (coalesce(lead_num,'X'))
	)


)--, start_end_of_shipment AS(
SELECT truck ,order_num ,st ,et
FROM(
	SELECT 
 		z.truck
		,z.order_num
		,z.timestamp st
		,y.timestamp et 
	FROM ededup_close z 
		LEFT JOIN dedup_close y ON z.truck = y.truck AND z.order_num = y.order_num AND z.rn+1 = y.rn AND z.status <>'Clsoed'
	WHERE z.status = 'Dispatch' 
)
	AS z
WHERE 
	z.timestamp BETWEEN left(@starttime,14) and left(@endtime,14)
	or z.timestamp BETWEEN left(@starttime,14) and left(@endtime,14)
	or( z.timestamp<= left(@starttime,14) and z.timestamp >= left(@endtime,14) )
ORDER BY order_num
